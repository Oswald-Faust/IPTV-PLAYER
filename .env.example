IPTV_URL=http://votre-serveur-iptv.com
IPTV_USER=votre_username
IPTV_PASS=votre_password
IPTV_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
IPTV_ACCEPT=application/json, text/plain, */*
IPTV_ACCEPT_LANGUAGE=fr-FR,fr;q=0.9,en-US;q=0.8,en;q=0.7
# Optionnel selon le fournisseur:
# IPTV_ORIGIN=https://example.com
# IPTV_REFERER=https://example.com/
# IPTV_X_REQUESTED_WITH=com.nst.iptvsmarterspro
PORT=3000
